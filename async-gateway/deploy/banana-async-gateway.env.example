# Async gateway listen address.
LISTEN_ADDR=:8080

# Local NewAPI base URL that still handles auth and billing.
NEWAPI_BASE_URL=http://newapi:3000

# PostgreSQL DSN for tasks + task_payloads tables.
POSTGRES_DSN=postgres://banana:banana@postgres:5432/banana_async_gateway?sslmode=disable

# HMAC secret used to derive owner_hash from the caller's API key.
OWNER_HASH_SECRET=replace-with-random-secret

# Base64-encoded 32-byte key used to encrypt stored Authorization headers.
TASK_PAYLOAD_ENCRYPTION_KEY=replace-with-base64-32-byte-key

# PostgreSQL connection pool sizing.
POSTGRES_MAX_OPEN_CONNS=20
POSTGRES_MAX_IDLE_CONNS=10

# Local worker and queue sizing.
MAX_INFLIGHT_TASKS=32
MAX_QUEUE_SIZE=256

# Polling guidance returned to clients.
TASK_POLL_RETRY_AFTER_SEC=10

# Timeout from async gateway to local NewAPI.
NEWAPI_REQUEST_TIMEOUT_MS=660000

# Grace period before shutdown forces in-flight dispatched tasks to uncertain.
SHUTDOWN_GRACE_PERIOD_SEC=30
